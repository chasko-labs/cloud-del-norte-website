{
  "Name": "daily-cost-aggregator",
  "Description": "Triggers cost aggregation Lambda daily at 06:00 UTC",
  "ScheduleExpression": "cron(0 6 * * ? *)",
  "State": "ENABLED",
  "Targets": [
    {
      "Id": "cost-aggregator-lambda",
      "Arn": "arn:aws:lambda:us-east-1:170473530355:function:cost-aggregator"
    }
  ]
}
